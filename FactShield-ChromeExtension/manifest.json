{
  "manifest_version": 3,
  "name": "FactShield",
  "description": "Real-time fact-checking powered by AI",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "offscreen",
    "tabs"
  ],
  "host_permissions": [
    "https://dashscope-intl.aliyuncs.com/*",
    "https://api.tavily.com/*",
    "https://factchecktools.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FactShield - Real-time Fact Checking"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://open.spotify.com/*",
        "*://*.spotify.com/*",
        "*://*/*"
      ],
      "js": ["src/content/extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
